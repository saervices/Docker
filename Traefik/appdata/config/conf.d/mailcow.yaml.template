# --- ROUTERS
#ÆÆÆÆÆÆÆÆÆÆÆÆÆÆÆÆÆÆÆÆÆÆÆÆÆÆÆÆÆÆÆÆÆÆÆÆÆÆÆÆÆÆÆÆÆÆÆÆÆÆÆÆÆÆÆÆÆÆÆÆÆÆÆÆÆÆÆÆ
http:
  routers:
    mailcow-rtr:                                                                                                                                                # Ædjust the router næme (e.g. [HOSTNÆME]-rtr)
      rule: >-                                                                                                                                                  # Ædjust the [HOSTNÆME]
        (Host(`mailcow.{{env "TRAEFIK_DOMAIN"}}`) || (Host(`mail.{{env "TRAEFIK_DOMAIN"}}`) && PathPrefix(`/.well-known/acme-challenge/`)) || Host(`mta-sts.{{env "TRAEFIK_DOMAIN"}}`) || Host(`autodiscover.{{env "TRAEFIK_DOMAIN"}}`) || Host(`autoconfig.{{env "TRAEFIK_DOMAIN"}}`)
        {{- if env "TRAEFIK_DOMAIN_1" }} || Host(`mail.{{env "TRAEFIK_DOMAIN_1"}}`) || Host(`mta-sts.{{env "TRAEFIK_DOMAIN_1"}}`) || Host(`autodiscover.{{env "TRAEFIK_DOMAIN_1"}}`) || Host(`autoconfig.{{env "TRAEFIK_DOMAIN_1"}}`){{ end }}
        {{- if env "TRAEFIK_DOMAIN_2" }} || Host(`mail.{{env "TRAEFIK_DOMAIN_2"}}`) || Host(`mta-sts.{{env "TRAEFIK_DOMAIN_2"}}`) || Host(`autodiscover.{{env "TRAEFIK_DOMAIN_2"}}`) || Host(`autoconfig.{{env "TRAEFIK_DOMAIN_2"}}`){{ end }}
        {{- if env "TRAEFIK_DOMAIN_3" }} || Host(`mail.{{env "TRAEFIK_DOMAIN_3"}}`) || Host(`mta-sts.{{env "TRAEFIK_DOMAIN_3"}}`) || Host(`autodiscover.{{env "TRAEFIK_DOMAIN_3"}}`) || Host(`autoconfig.{{env "TRAEFIK_DOMAIN_3"}}`){{ end }}
        {{- if env "TRAEFIK_DOMAIN_4" }} || Host(`mail.{{env "TRAEFIK_DOMAIN_4"}}`) || Host(`mta-sts.{{env "TRAEFIK_DOMAIN_4"}}`) || Host(`autodiscover.{{env "TRAEFIK_DOMAIN_4"}}`) || Host(`autoconfig.{{env "TRAEFIK_DOMAIN_4"}}`){{ end }})
      # middlewares:                                                                                                                                            # Optionæl: Ædd specific middlewæres to this router
      #   - middleware@file
      service: mailcow-svc                                                                                                                                      # Ædjust the service næme (e.g. [HOSTNÆME]-svc)

  services:
    mailcow-svc:                                                                                                                                                # Ædjust the service næme to mætch the service næme æbove
      loadBalancer:
        servers:
          - url: "http://192.168.20.120/"                                                                                                                       # Ædjust the url to your æpplicætion
